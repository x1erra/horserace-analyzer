# Horse Racing Tool Environment Variables
# Copy this file to .env and fill in your actual values

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Optional: Flask Configuration
FLASK_ENV=production
# Production images for Portainer/Git-based deploys.
IMAGE_REGISTRY=ghcr.io/x1erra
IMAGE_TAG=latest

# Published host ports.
BACKEND_PUBLISHED_PORT=5001
MCP_PUBLISHED_PORT=8001

# Optional: Runtime alert tuning
ALERT_STARTUP_GRACE_MINUTES=15
ACTIVE_CRAWL_GRACE_MINUTES=20
CRAWL_ALERT_CONFIRM_EVALUATIONS=3
ENTRIES_STALE_MINUTES=300
RESULTS_STALE_MINUTES=30
SCRATCHES_STALE_MINUTES=20
SUPABASE_POSTGREST_TIMEOUT_SECONDS=15

# Frontend API Configuration (VITE_ prefix required for React/Vite)
# If you change BACKEND_PUBLISHED_PORT, update VITE_API_URL to match.
VITE_API_URL=http://localhost:5001
VITE_APP_PASSWORD=your_secure_password_here
